<%- include("partials/header.ejs") %>

    <div class="hero-section text-dark">
        <div class="container py-5">
            <div class="row flex-lg-row-reverse align-items-center g-5 py-5">
                <div class="col-10 col-sm-8 col-lg-6 relative">
                    <div class="hero-image-wrapper">
                        <img src="/images/zoom.jpg" class="d-block mx-lg-auto img-fluid shadow-lg rounded-4 hero-img"
                            alt="Briefly Zoom Integration" width="700" height="500" loading="lazy">
                    </div>
                </div>
                <div class="col-lg-6">
                    <span
                        class="badge bg-primary-subtle text-primary mb-3 px-3 py-2 rounded-pill fw-semibold">AI-Powered
                        Zoom Assistant</span>
                    <h1 class="display-4 fw-extrabold lh-1 mb-4 text-gradient">Transform Meetings into Actionable
                        Insights</h1>
                    <p class="lead mb-4 text-secondary">Focus on the conversation, not the notes. Briefly seamlessly
                        integrates with Zoom to automatically capture, summarize, and organize your daily standups and
                        client calls in real-time.</p>
                    <div class="d-grid gap-3 d-md-flex justify-content-md-start">
                        <button type="button"
                            class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-sm custom-btn-primary">Get
                            Started Free</button>
                        <button type="button"
                            class="btn btn-outline-dark btn-lg px-5 py-3 rounded-pill fw-bold custom-btn-outline">Watch
                            Demo</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="reviews-section bg-light py-5">
        <div class="container py-5 my-4">
            <div class="text-center mb-5">
                <h2 class="display-5 fw-bold mb-3">Trusted by High-Performing Teams</h2>
                <p class="lead text-muted">See how professionals are reclaiming their time with Briefly.</p>
            </div>

            <div id="reviewsCarousel" class="carousel slide testimonial-carousel" data-bs-ride="carousel">
                <div class="carousel-inner shadow-sm rounded-5 bg-white p-4 p-md-5">

                    <div class="carousel-item active text-center px-3 px-md-5">
                        <div class="mx-auto" style="max-width: 700px;">
                            <div class="stars mb-3">⭐⭐⭐⭐⭐</div>
                            <p class="fs-4 fst-italic text-dark mb-4 fw-light">"Briefly's Zoom integration is flawless.
                                It summarizes my hour-long syncs into concise bullet points and catches action items I
                                completely missed. A total lifesaver for product teams."</p>
                            <div class="d-flex align-items-center justify-content-center gap-3">
                                <div class="avatar-circle">SJ</div>
                                <div class="text-start">
                                    <h5 class="mb-0 fw-bold">Sarah Jenkins</h5>
                                    <p class="text-muted small mb-0">Product Manager</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="carousel-item text-center px-3 px-md-5">
                        <div class="mx-auto" style="max-width: 700px;">
                            <div class="stars mb-3">⭐⭐⭐⭐⭐</div>
                            <p class="fs-4 fst-italic text-dark mb-4 fw-light">"I used to spend hours typing up meeting
                                notes and distributing them to the team. Now, the intelligent AI does it for me
                                instantly the second the Zoom call ends. Incredible ROI."</p>
                            <div class="d-flex align-items-center justify-content-center gap-3">
                                <div class="avatar-circle">MT</div>
                                <div class="text-start">
                                    <h5 class="mb-0 fw-bold">Mark T.</h5>
                                    <p class="text-muted small mb-0">VP of Sales</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="carousel-item text-center px-3 px-md-5">
                        <div class="mx-auto" style="max-width: 700px;">
                            <div class="stars mb-3">⭐⭐⭐⭐⭐</div>
                            <p class="fs-4 fst-italic text-dark mb-4 fw-light">"Connecting this to our daily Zoom
                                standups changed everything. No more confusing threads or forgotten tasks—just pure,
                                intelligent clarity delivered straight to our inbox."</p>
                            <div class="d-flex align-items-center justify-content-center gap-3">
                                <div class="avatar-circle">DK</div>
                                <div class="text-start">
                                    <h5 class="mb-0 fw-bold">David K.</h5>
                                    <p class="text-muted small mb-0">CTO</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="carousel-item text-center px-3 px-md-5">
                        <div class="mx-auto" style="max-width: 700px;">
                            <div class="stars mb-3">⭐⭐⭐⭐⭐</div>
                            <p class="fs-4 fst-italic text-dark mb-4 fw-light">"The accuracy of Briefly's AI is
                                mind-blowing. It perfectly distinguishes between different speakers on Zoom and strips
                                out all the small talk to give me exactly what I need."</p>
                            <div class="d-flex align-items-center justify-content-center gap-3">
                                <div class="avatar-circle">ER</div>
                                <div class="text-start">
                                    <h5 class="mb-0 fw-bold">Emily R.</h5>
                                    <p class="text-muted small mb-0">Senior Developer</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

                <button class="carousel-control-prev custom-nav-btn" type="button" data-bs-target="#reviewsCarousel"
                    data-bs-slide="prev">
                    <span class="carousel-control-prev-icon shadow-sm" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next custom-nav-btn" type="button" data-bs-target="#reviewsCarousel"
                    data-bs-slide="next">
                    <span class="carousel-control-next-icon shadow-sm" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </div>

